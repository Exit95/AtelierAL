---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
    <div class="container footer-content">
        <div class="footer-section footer-brand-section">
            <div class="footer-brand">
                <img src="/logo-kl.png" alt="ATELIER KL" class="footer-logo" />
                <div>
                    <h3>ATELIER KL</h3>
                    <p class="footer-tagline">Kunst, die Räume verwandelt</p>
                </div>
            </div>
            <p class="footer-description">
                Abstrakte Kunstwerke und inspirierende Workshops von Katharina Lanvermann in Ahaus.
            </p>
        </div>

        <div class="footer-section">
            <h4>Navigation</h4>
            <ul class="footer-links">
                <li><a href="/">Home</a></li>
                <li><a href="/werke">Werke</a></li>
                <li><a href="/auftragsarbeiten">Auftragsarbeiten</a></li>
                <li><a href="/workshops">Workshops</a></li>
                <li><a href="/team">Über mich</a></li>
                <li><a href="/kontakt">Kontakt</a></li>
            </ul>
        </div>

        <div class="footer-section">
            <h4>Kontakt</h4>
            <address class="footer-contact">
                <p>Katharina Lanvermann</p>
                <p>Bockhorn 68</p>
                <p>48683 Ahaus</p>
                <p class="footer-email">
                    <a href="mailto:studio@atelierkl.de">studio@atelierkl.de</a>
                </p>
            </address>
        </div>

        <div class="footer-section">
            <h4>Rechtliches</h4>
            <ul class="footer-links">
                <li><a href="/impressum">Impressum</a></li>
                <li><a href="/datenschutz">Datenschutz</a></li>
                <li><a href="/rechtliches">AGB</a></li>
            </ul>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container">
            <p>
                &copy; {currentYear} ATELIER KL &mdash; Katharina Lanvermann
            </p>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background-color: var(--color-dark);
        color: var(--color-gray-200);
        padding-top: var(--space-12);
        padding-bottom: var(--space-6);
        margin-top: 0;
    }

    .footer-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
        margin-bottom: var(--space-10);
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        margin-bottom: var(--space-4);
    }

    .footer-logo {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .footer-brand h3 {
        font-size: var(--font-size-lg);
        color: var(--color-white);
        margin: 0;
        letter-spacing: var(--letter-spacing-wider);
    }

    .footer-tagline {
        color: var(--color-gray-400);
        margin: 0;
        font-size: var(--font-size-sm);
    }

    .footer-description {
        color: var(--color-gray-400);
        font-size: var(--font-size-sm);
        line-height: var(--line-height-relaxed);
        max-width: 280px;
    }

    .footer-section h4 {
        font-family: var(--font-body);
        font-size: var(--font-size-xs);
        color: var(--color-brand-beige);
        margin-bottom: var(--space-4);
        font-weight: var(--font-weight-medium);
        letter-spacing: var(--letter-spacing-widest);
        text-transform: uppercase;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .footer-links a {
        color: var(--color-gray-300);
        text-decoration: none;
        transition: color var(--transition-fast);
        font-size: var(--font-size-sm);
        display: inline-block;
        padding: var(--space-2) 0;
        min-height: 44px;
        line-height: 2;
    }

    .footer-links a:hover {
        color: var(--color-brand-beige);
    }

    .footer-contact {
        font-style: normal;
        color: var(--color-gray-300);
        line-height: var(--line-height-relaxed);
        font-size: var(--font-size-sm);
    }

    .footer-contact p {
        margin-bottom: var(--space-1);
    }

    .footer-email {
        margin-top: var(--space-3) !important;
    }

    .footer-contact a {
        color: var(--color-brand-beige);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .footer-contact a:hover {
        color: var(--color-brand-beige-light);
    }

    .footer-bottom {
        border-top: 1px solid var(--color-gray-800);
        padding-top: var(--space-6);
        text-align: center;
    }

    .footer-bottom p {
        color: var(--color-gray-500);
        font-size: var(--font-size-xs);
        margin: 0;
        letter-spacing: var(--letter-spacing-wide);
    }

    @media (min-width: 768px) {
        .site-footer {
            padding-top: var(--space-16);
            padding-bottom: var(--space-8);
        }

        .footer-content {
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: var(--space-10);
            margin-bottom: var(--space-12);
        }
    }
</style>
