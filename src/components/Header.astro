---
const currentPath = Astro.url.pathname;

const navItems = [
    { label: "Home", href: "/" },
    { label: "Werke", href: "/werke" },
    { label: "Auftragsarbeiten", href: "/auftragsarbeiten" },
    { label: "Workshops", href: "/workshops" },
    { label: "Über mich", href: "/team" },
    { label: "Kontakt", href: "/kontakt" },
];
---

<header class="site-header" id="site-header">
    <div class="container header-content">
        <a href="/" class="logo-link">
            <img src="/logo-kl.png" alt="ATELIER KL" class="logo" />
        </a>

        <button
            class="mobile-menu-toggle"
            aria-label="Menü öffnen"
            aria-expanded="false"
            aria-controls="main-navigation"
        >
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>

        <nav id="main-navigation" aria-label="Hauptnavigation" class="main-nav">
            <ul class="nav-list">
                {
                    navItems.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                class={
                                    currentPath === item.href
                                        ? "nav-link active"
                                        : "nav-link"
                                }
                                aria-current={
                                    currentPath === item.href
                                        ? "page"
                                        : undefined
                                }
                            >
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>

<script>
    const menuToggle = document.querySelector(
        ".mobile-menu-toggle",
    ) as HTMLButtonElement | null;
    const mainNav = document.querySelector(".main-nav") as HTMLElement | null;
    const body = document.body;
    const header = document.getElementById("site-header");

    // Scroll-based header background
    if (header) {
        const updateHeader = () => {
            if (window.scrollY > 60) {
                header.classList.add("scrolled");
            } else {
                header.classList.remove("scrolled");
            }
        };
        window.addEventListener("scroll", updateHeader, { passive: true });
        updateHeader();
    }

    if (menuToggle && mainNav) {
        menuToggle.addEventListener("click", () => {
            const isExpanded =
                menuToggle.getAttribute("aria-expanded") === "true";

            menuToggle.setAttribute("aria-expanded", (!isExpanded).toString());
            menuToggle.setAttribute(
                "aria-label",
                isExpanded ? "Menü öffnen" : "Menü schließen",
            );
            menuToggle.classList.toggle("active");
            mainNav.classList.toggle("active");
            body.classList.toggle("menu-open");
        });

        const navLinks = mainNav.querySelectorAll(".nav-link");
        navLinks.forEach((link) => {
            link.addEventListener("click", () => {
                menuToggle.setAttribute("aria-expanded", "false");
                menuToggle.setAttribute("aria-label", "Menü öffnen");
                menuToggle.classList.remove("active");
                mainNav.classList.remove("active");
                body.classList.remove("menu-open");
            });
        });

        document.addEventListener("click", (e) => {
            const target = e.target as Node;
            if (!mainNav.contains(target) && !menuToggle.contains(target)) {
                if (mainNav.classList.contains("active")) {
                    menuToggle.setAttribute("aria-expanded", "false");
                    menuToggle.setAttribute("aria-label", "Menü öffnen");
                    menuToggle.classList.remove("active");
                    mainNav.classList.remove("active");
                    body.classList.remove("menu-open");
                }
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && mainNav.classList.contains("active")) {
                menuToggle.setAttribute("aria-expanded", "false");
                menuToggle.setAttribute("aria-label", "Menü öffnen");
                menuToggle.classList.remove("active");
                mainNav.classList.remove("active");
                body.classList.remove("menu-open");
                menuToggle.focus();
            }
        });
    }
</script>

<style>
    .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: var(--z-sticky);
        background-color: transparent;
        transition: background-color 0.3s ease, box-shadow 0.3s ease;
    }

    .site-header.scrolled {
        background-color: rgba(253, 252, 250, 0.95);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: var(--shadow-sm);
    }

    .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: var(--space-3);
        padding-top: var(--space-3);
        padding-bottom: var(--space-3);
    }

    .logo-link {
        display: flex;
        align-items: center;
        text-decoration: none;
        flex-shrink: 0;
    }

    .logo {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        transition: transform var(--transition-fast);
    }

    .logo-link:hover .logo {
        transform: scale(1.05);
    }

    /* Mobile Menu Toggle */
    .mobile-menu-toggle {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        width: 44px;
        height: 44px;
        padding: 0;
        background: transparent;
        border: none;
        cursor: pointer;
        z-index: calc(var(--z-sticky) + 2);
        transition: transform var(--transition-base);
    }

    .mobile-menu-toggle:hover {
        transform: scale(1.05);
    }

    .hamburger-line {
        width: 24px;
        height: 2px;
        background-color: var(--color-text-dark);
        border-radius: 1px;
        transition: all var(--transition-base);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
        opacity: 0;
        transform: translateX(-10px);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Navigation */
    .main-nav {
        position: fixed;
        top: 0;
        right: -100%;
        width: 300px;
        height: 100vh;
        height: 100dvh;
        background-color: var(--color-white);
        box-shadow: var(--shadow-lg);
        z-index: calc(var(--z-sticky) + 1);
        transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow-y: auto;
        padding-top: 80px;
    }

    .main-nav.active {
        right: 0;
    }

    .nav-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        list-style: none;
        margin: 0;
        padding: var(--space-4);
    }

    .nav-link {
        font-family: var(--font-body);
        font-size: var(--font-size-base);
        font-weight: var(--font-weight-normal);
        color: var(--color-text-primary);
        text-decoration: none;
        padding: var(--space-4);
        transition: all var(--transition-fast);
        display: block;
        border-bottom: 1px solid var(--color-border-light);
    }

    .nav-link:hover,
    .nav-link.active {
        color: var(--color-accent);
    }

    :global(body.menu-open) {
        overflow: hidden;
    }

    @media (min-width: 375px) {
        .logo {
            width: 44px;
            height: 44px;
        }
    }

    @media (min-width: 768px) {
        .header-content {
            flex-wrap: nowrap;
            padding-top: var(--space-4);
            padding-bottom: var(--space-4);
        }

        .logo {
            width: 48px;
            height: 48px;
        }

        .mobile-menu-toggle {
            display: none;
        }

        .main-nav {
            position: static;
            width: auto;
            height: auto;
            background: transparent;
            box-shadow: none;
            padding-top: 0;
            overflow-y: visible;
        }

        .nav-list {
            flex-direction: row;
            padding: 0;
            gap: var(--space-2);
        }

        .nav-link {
            font-size: var(--font-size-sm);
            font-weight: var(--font-weight-normal);
            padding: var(--space-2) var(--space-3);
            border-bottom: none;
            border-radius: var(--radius-base);
            letter-spacing: var(--letter-spacing-wide);
        }

        .nav-link:hover {
            background-color: rgba(139, 115, 85, 0.08);
        }

        .nav-link.active {
            color: var(--color-accent);
            background-color: rgba(139, 115, 85, 0.08);
        }
    }

    @media (min-width: 1024px) {
        .logo {
            width: 52px;
            height: 52px;
        }

        .nav-list {
            gap: var(--space-1);
        }

        .nav-link {
            padding: var(--space-2) var(--space-4);
        }
    }
</style>
