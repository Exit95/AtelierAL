---
interface Props {
    title: string;
    subtitle?: string;
    backgroundImage?: string;
    primaryCTA?: { label: string; href: string };
    secondaryCTA?: { label: string; href: string };
}

const { title, subtitle, backgroundImage, primaryCTA, secondaryCTA } =
    Astro.props;
import CTAButton from "./CTAButton.astro";
---

<section
    class="hero"
    style={backgroundImage ? `background-image: url(${backgroundImage})` : ""}
>
    <div class="hero-overlay"></div>
    <div class="hero-content container">
        <img src="/atelier5.png" alt="ATELIER KL" class="hero-logo" width="450" height="auto" loading="eager" fetchpriority="high" />
        {subtitle && <p class="hero-subtitle">{subtitle}</p>}
        {
            (primaryCTA || secondaryCTA) && (
                <div class="hero-ctas">
                    {primaryCTA && (
                        <CTAButton
                            label={primaryCTA.label}
                            href={primaryCTA.href}
                            type="primary"
                        />
                    )}
                    {secondaryCTA && (
                        <CTAButton
                            label={secondaryCTA.label}
                            href={secondaryCTA.href}
                            type="secondary"
                        />
                    )}
                </div>
            )
        }
        <div class="hero-scroll-hint" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-image: url('/hintergrund.webp');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        overflow: hidden;
        padding: var(--space-16) 0 var(--space-8);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            rgba(253, 252, 250, 0.1) 0%,
            rgba(253, 252, 250, 0.05) 40%,
            rgba(253, 252, 250, 0.15) 100%
        );
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        animation: fadeIn 0.8s ease-out;
        padding: var(--space-4);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .hero-logo {
        width: 200px;
        height: auto;
        margin-bottom: var(--space-6);
        object-fit: contain;
    }

    .hero-subtitle {
        font-family: var(--font-script);
        font-size: var(--font-size-lg);
        font-weight: var(--font-weight-normal);
        max-width: 90%;
        margin: 0 auto var(--space-8);
        color: var(--color-text-secondary);
        line-height: var(--line-height-relaxed);
    }

    .hero-ctas {
        display: flex;
        gap: var(--space-3);
        justify-content: center;
        flex-wrap: wrap;
    }

    .hero-scroll-hint {
        position: absolute;
        bottom: var(--space-8);
        left: 50%;
        transform: translateX(-50%);
        color: var(--color-gray-400);
        animation: bounceDown 2s infinite;
        opacity: 0.6;
    }

    @keyframes bounceDown {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50% { transform: translateX(-50%) translateY(8px); }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-scroll-hint {
            animation: none;
        }

        .hero-content {
            animation: none;
        }
    }

    /* Small smartphones: 375px+ */
    @media (min-width: 375px) {
        .hero-logo {
            width: 260px;
        }

        .hero-subtitle {
            font-size: var(--font-size-xl);
        }
    }

    /* Tablets: 768px+ */
    @media (min-width: 768px) {
        .hero {
            min-height: 75vh;
            padding: var(--space-16) 0;
        }

        .hero-logo {
            width: 360px;
            margin-bottom: var(--space-8);
        }

        .hero-subtitle {
            font-size: var(--font-size-xl);
            max-width: 600px;
            margin-bottom: var(--space-10);
        }

        .hero-ctas {
            gap: var(--space-4);
        }
    }

    /* Desktop: 1024px+ */
    @media (min-width: 1024px) {
        .hero {
            min-height: 85vh;
        }

        .hero-logo {
            width: 420px;
        }

        .hero-subtitle {
            max-width: 650px;
        }
    }

    /* Large desktop: 1440px+ */
    @media (min-width: 1440px) {
        .hero-logo {
            width: 500px;
        }

        .hero-subtitle {
            max-width: 700px;
        }
    }
</style>
