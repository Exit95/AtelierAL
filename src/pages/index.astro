---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import CTAButton from "../components/CTAButton.astro";
import ReviewsDisplay from "../components/ReviewsDisplay.astro";
import ReviewForm from "../components/ReviewForm.astro";
import { getItems, type Artwork, type Workshop } from "../lib/storage";

const allArtworks = await getItems<Artwork>("artworks");
const featuredArtworks = allArtworks
	.filter((artwork) => artwork.featured)
	.slice(0, 6);

const allWorkshops = await getItems<Workshop>("workshops");
const upcomingWorkshops = allWorkshops
	.filter((workshop) => new Date(workshop.date) > new Date())
	.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
	.slice(0, 3);
---

<Layout
	title="Home"
	description="ATELIER KL - Abstrakte Kunst von Katharina Lanvermann. Entdecken Sie einzigartige Kunstwerke und kreative Workshops in Ahaus."
>
	<HeroSection
		title="Kunst, die Räume verwandelt"
		subtitle="Abstrakte Kunstwerke und inspirierende Workshops von Katharina Lanvermann"
		primaryCTA={{ label: "Werke entdecken", href: "/werke" }}
		secondaryCTA={{ label: "Workshop buchen", href: "/workshops" }}
	/>

	<!-- Featured Artworks -->
	<section class="section py-20 section-dark">
		<div class="container">
			<div class="section-header">
				<p class="section-label">Galerie</p>
				<h2 class="handwriting">Ausgewählte Werke</h2>
				<div class="divider"></div>
				<p class="subtitle">Eine Auswahl meiner neuesten abstrakten Kunstwerke</p>
			</div>

			{
				featuredArtworks.length > 0 ? (
					<>
						<div class="carousel-container">
							<button class="carousel-btn carousel-btn-prev" aria-label="Vorheriges Werk">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
							</button>
							<div class="carousel-track-wrapper">
								<div class="carousel-track">
									{featuredArtworks.map((artwork, index) => (
										<div
											class="carousel-slide"
											data-lightbox-trigger
											data-image-url={artwork.images[0]}
											data-artwork-index={index}
										>
											<div class="artwork-card">
												<div class="artwork-image-wrapper">
													<img
														src={artwork.images[0]}
														alt={artwork.title}
														loading="lazy"
														decoding="async"
														width="600"
														height="600"
													/>
													<div class="artwork-overlay">
														<span class="view-text">Ansehen</span>
													</div>
												</div>
												<div class="artwork-info">
													<h3>{artwork.title}</h3>
													<p class="artwork-meta">
														{artwork.technique} &middot; {artwork.size.width} &times; {artwork.size.height} {artwork.size.unit}
													</p>
												</div>
											</div>
										</div>
									))}
								</div>
							</div>
							<button class="carousel-btn carousel-btn-next" aria-label="Nächstes Werk">
								<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
							</button>
						</div>
						<div class="carousel-dots"></div>
						<div class="section-cta">
							<CTAButton label="Alle Werke ansehen" href="/werke" type="secondary" />
						</div>
					</>
				) : (
					<p class="text-center text-secondary">
						Demnächst finden Sie hier ausgewählte Kunstwerke.
					</p>
				)
			}
		</div>
	</section>

	<!-- Workshops -->
	<section class="section py-20 section-warm">
		<div class="container">
			<div class="section-header">
				<p class="section-label dark">Workshops</p>
				<h2 class="handwriting dark">Kreative Kurse</h2>
				<div class="divider dark"></div>
				<p class="subtitle dark">
					Entdecken Sie Ihre künstlerische Seite in kleinen Gruppen
				</p>
			</div>

			{
				upcomingWorkshops.length > 0 ? (
					<>
						<div class="grid grid-cols-1 grid-cols-md-3">
							{upcomingWorkshops.map((workshop) => (
								<WorkshopCard workshop={workshop} />
							))}
						</div>
						<div class="section-cta">
							<CTAButton label="Alle Workshops" href="/workshops" type="primary" />
						</div>
					</>
				) : (
					<p class="text-center text-secondary">
						Neue Workshops werden in Kürze angekündigt. Schauen Sie bald wieder vorbei!
					</p>
				)
			}
		</div>
	</section>

	<!-- Commission Process -->
	<section class="section py-20 section-dark">
		<div class="container">
			<div class="section-header">
				<p class="section-label">Auftragsarbeiten</p>
				<h2 class="handwriting">Ihr persönliches Kunstwerk</h2>
				<div class="divider"></div>
				<p class="subtitle">Von der Idee bis zum fertigen Werk in drei Schritten</p>
			</div>

			<div class="process-steps">
				<div class="process-step">
					<div class="step-number">01</div>
					<div class="step-line"></div>
					<h3>Anfrage & Beratung</h3>
					<p>
						Teilen Sie mir Ihre Vorstellungen, Farbwünsche und
						Raummaße mit. Gemeinsam entwickeln wir ein Konzept.
					</p>
				</div>
				<div class="process-step">
					<div class="step-number">02</div>
					<div class="step-line"></div>
					<h3>Konzept & Entwurf</h3>
					<p>
						Ich erstelle einen ersten Entwurf und stimme ihn mit
						Ihnen ab, damit das Werk perfekt zu Ihren Wünschen passt.
					</p>
				</div>
				<div class="process-step">
					<div class="step-number">03</div>
					<div class="step-line"></div>
					<h3>Umsetzung & Übergabe</h3>
					<p>
						Ihr Kunstwerk wird mit großer Sorgfalt erschaffen und
						kann abgeholt oder geliefert werden.
					</p>
				</div>
			</div>

			<div class="section-cta">
				<CTAButton label="Werk anfragen" href="/auftragsarbeiten" type="secondary" />
			</div>
		</div>
	</section>

	<!-- Customer Reviews -->
	<section class="section py-20 section-alt">
		<div class="container">
			<ReviewsDisplay />
		</div>
	</section>

	<!-- Review Form -->
	<section class="section py-16">
		<div class="container">
			<ReviewForm title="Teilen Sie Ihre Erfahrung" />
		</div>
	</section>

	<!-- Final CTA -->
	<section class="section py-20 cta-section">
		<div class="container text-center">
			<p class="section-label">Bereit?</p>
			<h2 class="handwriting" style="color: var(--color-white);">
				Lassen Sie uns zusammenarbeiten
			</h2>
			<div class="divider" style="background-color: rgba(255,255,255,0.4);"></div>
			<p style="color: rgba(255,255,255,0.85); max-width: 550px; margin: var(--space-4) auto var(--space-8); font-size: var(--font-size-lg);">
				Kontaktieren Sie mich für eine unverbindliche Beratung oder
				buchen Sie einen Workshop.
			</p>
			<div class="flex gap-4 justify-center" style="flex-wrap: wrap;">
				<CTAButton label="Kontakt aufnehmen" href="/kontakt" type="primary" />
				<CTAButton label="Workshops ansehen" href="/workshops" type="secondary" />
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Section Label */
	.section-label {
		font-family: var(--font-body);
		font-size: var(--font-size-xs);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-widest);
		text-transform: uppercase;
		color: var(--color-brand-beige);
		margin-bottom: var(--space-3);
	}

	.section-label.dark {
		color: var(--color-accent);
	}

	.section-dark .subtitle {
		color: var(--color-gray-300);
	}

	.subtitle.dark {
		color: var(--color-text-secondary);
	}

	.handwriting.dark {
		color: var(--color-text-dark);
	}

	.divider.dark {
		background-color: var(--color-accent);
	}

	/* CTA Section */
	.cta-section {
		background: linear-gradient(135deg, var(--color-dark) 0%, var(--color-dark-alt) 100%);
		position: relative;
		overflow: hidden;
	}

	.cta-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: radial-gradient(circle at 30% 50%, rgba(196, 168, 130, 0.08) 0%, transparent 50%);
	}

	.cta-section .container {
		position: relative;
		z-index: 1;
	}

	.cta-section .cta-button-secondary {
		color: var(--color-brand-beige);
		border-color: var(--color-brand-beige);
	}

	.cta-section .cta-button-secondary:hover {
		background-color: var(--color-brand-beige);
		color: var(--color-dark);
	}

	/* Artwork Cards */
	.artwork-card {
		border-radius: var(--radius-lg);
		overflow: hidden;
		background: var(--color-gray-800);
		transition: transform var(--transition-base), box-shadow var(--transition-base);
	}

	.artwork-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-lg);
	}

	.artwork-image-wrapper {
		position: relative;
		overflow: hidden;
		aspect-ratio: 1;
	}

	.artwork-image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
		border-radius: 0;
	}

	.artwork-card:hover .artwork-image-wrapper img {
		transform: scale(1.05);
	}

	.artwork-overlay {
		position: absolute;
		inset: 0;
		background: rgba(20, 18, 17, 0.5);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.artwork-card:hover .artwork-overlay {
		opacity: 1;
	}

	.view-text {
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		font-weight: var(--font-weight-medium);
		letter-spacing: var(--letter-spacing-wider);
		text-transform: uppercase;
		color: var(--color-white);
		padding: var(--space-2) var(--space-4);
		border: 1px solid rgba(255, 255, 255, 0.6);
		border-radius: var(--radius-base);
	}

	.artwork-info {
		padding: var(--space-4) var(--space-5);
	}

	.artwork-info h3 {
		font-size: var(--font-size-base);
		font-weight: var(--font-weight-medium);
		color: var(--color-white);
		margin-bottom: var(--space-1);
	}

	.artwork-meta {
		font-size: var(--font-size-xs);
		color: var(--color-gray-400);
		margin: 0;
	}

	/* Process Steps */
	.process-steps {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
	}

	@media (min-width: 768px) {
		.process-steps {
			grid-template-columns: repeat(3, 1fr);
			gap: var(--space-10);
		}
	}

	.process-step {
		text-align: center;
		position: relative;
	}

	.step-number {
		font-family: var(--font-headline);
		font-size: var(--font-size-5xl);
		font-weight: var(--font-weight-bold);
		color: var(--color-brand-beige);
		opacity: 0.3;
		line-height: 1;
		margin-bottom: var(--space-2);
	}

	.step-line {
		width: 40px;
		height: 2px;
		background-color: var(--color-brand-beige);
		margin: 0 auto var(--space-4);
	}

	.process-step h3 {
		color: var(--color-white);
		font-size: var(--font-size-lg);
		margin-bottom: var(--space-3);
	}

	.process-step p {
		color: var(--color-gray-300);
		font-size: var(--font-size-sm);
		line-height: var(--line-height-relaxed);
		max-width: 280px;
		margin: 0 auto;
	}

	/* Carousel */
	.carousel-container {
		position: relative;
		display: flex;
		align-items: center;
		gap: var(--space-4);
	}

	.carousel-track-wrapper {
		overflow: hidden;
		flex: 1;
	}

	.carousel-track {
		display: flex;
		gap: var(--space-6);
		transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.carousel-slide {
		flex: 0 0 100%;
		min-width: 0;
		cursor: pointer;
	}

	@media (min-width: 640px) {
		.carousel-slide {
			flex: 0 0 calc(50% - var(--space-3));
		}
	}

	@media (min-width: 1024px) {
		.carousel-slide {
			flex: 0 0 calc(33.333% - var(--space-4));
		}
	}

	.carousel-btn {
		flex-shrink: 0;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: rgba(196, 168, 130, 0.15);
		color: var(--color-brand-beige);
		border: 1px solid rgba(196, 168, 130, 0.3);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s ease;
	}

	.carousel-btn:hover {
		background: var(--color-brand-beige);
		color: var(--color-dark);
		border-color: var(--color-brand-beige);
	}

	.carousel-btn:disabled {
		opacity: 0.2;
		cursor: not-allowed;
	}

	@media (max-width: 639px) {
		.carousel-btn {
			display: none;
		}
	}

	.carousel-dots {
		display: flex;
		justify-content: center;
		gap: var(--space-2);
		margin-top: var(--space-8);
	}

	.carousel-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--color-gray-600);
		border: none;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.carousel-dot.active {
		background: var(--color-brand-beige);
		width: 24px;
		border-radius: 4px;
	}

	.carousel-dot:hover {
		background: var(--color-brand-beige-light);
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const track = document.querySelector('.carousel-track') as HTMLElement;
		const slides = document.querySelectorAll('.carousel-slide');
		const prevBtn = document.querySelector('.carousel-btn-prev') as HTMLButtonElement;
		const nextBtn = document.querySelector('.carousel-btn-next') as HTMLButtonElement;
		const dotsContainer = document.querySelector('.carousel-dots') as HTMLElement;

		if (!track || slides.length === 0) return;

		let currentIndex = 0;
		let slidesPerView = 1;
		let autoplayInterval: ReturnType<typeof setInterval>;

		function updateSlidesPerView() {
			if (window.innerWidth >= 1024) {
				slidesPerView = 3;
			} else if (window.innerWidth >= 640) {
				slidesPerView = 2;
			} else {
				slidesPerView = 1;
			}
		}

		function createDots() {
			dotsContainer.innerHTML = '';
			const totalDots = Math.ceil(slides.length / slidesPerView);
			for (let i = 0; i < totalDots; i++) {
				const dot = document.createElement('button');
				dot.classList.add('carousel-dot');
				if (i === 0) dot.classList.add('active');
				dot.addEventListener('click', () => goToSlide(i * slidesPerView));
				dotsContainer.appendChild(dot);
			}
		}

		function updateDots() {
			const dots = document.querySelectorAll('.carousel-dot');
			const activeDotIndex = Math.floor(currentIndex / slidesPerView);
			dots.forEach((dot, i) => {
				dot.classList.toggle('active', i === activeDotIndex);
			});
		}

		function goToSlide(index: number) {
			const maxIndex = slides.length - slidesPerView;
			currentIndex = Math.max(0, Math.min(index, maxIndex));

			const slideWidth = (slides[0] as HTMLElement).offsetWidth;
			const gap = 24;
			track.style.transform = `translateX(-${currentIndex * (slideWidth + gap)}px)`;

			updateDots();
			updateButtons();
		}

		function updateButtons() {
			if (prevBtn) prevBtn.disabled = currentIndex === 0;
			if (nextBtn) nextBtn.disabled = currentIndex >= slides.length - slidesPerView;
		}

		function nextSlide() {
			if (currentIndex < slides.length - slidesPerView) {
				goToSlide(currentIndex + 1);
			} else {
				goToSlide(0);
			}
		}

		function prevSlide() {
			if (currentIndex > 0) {
				goToSlide(currentIndex - 1);
			}
		}

		function startAutoplay() {
			autoplayInterval = setInterval(nextSlide, 5000);
		}

		function stopAutoplay() {
			clearInterval(autoplayInterval);
		}

		if (prevBtn) prevBtn.addEventListener('click', () => { stopAutoplay(); prevSlide(); startAutoplay(); });
		if (nextBtn) nextBtn.addEventListener('click', () => { stopAutoplay(); nextSlide(); startAutoplay(); });

		track.addEventListener('mouseenter', stopAutoplay);
		track.addEventListener('mouseleave', startAutoplay);

		window.addEventListener('resize', () => {
			updateSlidesPerView();
			createDots();
			goToSlide(0);
		});

		updateSlidesPerView();
		createDots();
		updateButtons();
		startAutoplay();
	});
</script>
