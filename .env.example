# Admin Authentication
ADMIN_USERNAME=admin
# Preferred: bcrypt hash (generate with: node -e "import('bcrypt').then(b=>b.default.hash('YOUR_PASSWORD',12).then(console.log))")
ADMIN_PASSWORD_HASH=
# Fallback: plain-text password (NOT recommended for production)
ADMIN_PASSWORD=CHANGE_ME_MIN_16_CHARS
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX_STRING

# SQLite Database
DB_PATH=/app/data/atelierkl.db

# Hetzner Object Storage (S3-compatible)
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=nbg1
S3_BUCKET=danapfel-digital
S3_ACCESS_KEY=dein-access-key
S3_SECRET_KEY=dein-secret-key

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=dein-smtp-benutzer
SMTP_PASS=dein-smtp-passwort

# Email Addresses
FROM_EMAIL=noreply@atelierkl.de
ADMIN_EMAIL=studio@atelierkl.de

# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
